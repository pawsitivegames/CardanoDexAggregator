# Primary chain-state provider (see docs/decisions/infra.md — T1.1).
# Maestro entry tier: UTxO state + datum resolution + mempool-aware DEX prices + submit.
# Get a key at https://gomaestro.org
MAESTRO_MAINNET_API_KEY=yourMaestroMainnetKey
MAESTRO_PREPROD_API_KEY=yourMaestroPreprodKey

# Fallback chain reads: server-side Blockfrost project IDs.
# Get a free API key at https://blockfrost.io
BLOCKFROST_MAINNET_PROJECT_ID=mainnetYourProjectIdHere
BLOCKFROST_PREPROD_PROJECT_ID=preprodYourProjectIdHere
BLOCKFROST_PREVIEW_PROJECT_ID=previewYourProjectIdHere
CARDEXSCAN_API_BASE_URL=https://cardexscan.com/api/cds
CARDEXSCAN_API_KEY=yourCardexscanApiKey
SATURN_API_KEY=yourSaturnApiKey

# Optional browser-visible partner IDs for live adapters.
VITE_DEXHUNTER_PARTNER_ID=yourDexHunterPartnerId
VITE_STEELSWAP_PARTNER=clearroute-aggregator
